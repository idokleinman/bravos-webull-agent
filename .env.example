# ─────────────────────────────────────────────────────────────────────────────
# Bravos → Telegram → Webull agent — secrets & config
# Copy to `.env`, fill in, keep private (git-ignored). `sync_secrets.py` pushes
# the SECRET_* values into SSM SecureString. Toggles are passed as Lambda env vars
# by the SAM template (see template.yaml Parameters), NOT stored as secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── AWS / deploy ─────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
# SSM path prefix under which secrets are written/read (least-priv IAM scopes to it)
SSM_PREFIX=/bravos-webull/prod
# S3 bucket holding state.json (created by SAM; set after first deploy)
STATE_BUCKET=

# ── Safety toggles (defaults are SAFE — off & dry) ──────────────────────────
TRADING_ENABLED=false
DRY_RUN=true
# KILL_SWITCH is stored in SSM (so it halts without redeploy): any non-empty value halts.
KILL_SWITCH=

# ── Sizing / risk ───────────────────────────────────────────────────────────
TARGET_NOTIONAL=11000
MAX_ORDER_NOTIONAL=12000
STOP_PCT_QQQ=0.10
STOP_PCT_TQQQ=0.20
CONFIRM_WINDOW_MINUTES=10

# ── Webull ──────────────────────────────────────────────────────────────────
WEBULL_ENV=uat                 # uat (sandbox) | prod
WEBULL_REGION_ID=us
WEBULL_ACCOUNT_ID=8PHS8R40VL7GC7G9LJTK62DEB9
SECRET_WEBULL_APP_KEY=
SECRET_WEBULL_APP_SECRET=

# ── Gmail (OAuth installed-app; refresh token from setup_oauth.py) ──────────
SECRET_GMAIL_CLIENT_ID=
SECRET_GMAIL_CLIENT_SECRET=
SECRET_GMAIL_REFRESH_TOKEN=

# ── Telegram ────────────────────────────────────────────────────────────────
SECRET_TELEGRAM_BOT_TOKEN=
SECRET_TELEGRAM_CHAT_ID=

# ── Testing only (Layer 3). Honored ONLY when DRY_RUN=true; refuses to arm. ──
TEST_EMAIL_MODE=false
TEST_SENDER=
